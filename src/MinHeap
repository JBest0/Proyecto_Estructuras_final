/**
 * Montículo mínimo (min-heap) para almacenar aristas.
 *
 * <p>La arista de menor peso siempre está en la raíz (índice 0).
 * Proporciona las tres operaciones que necesita el algoritmo de Prim:
 * <ul>
 *   <li>insert(edge) — O(log n)</li>
 *   <li>extractMin() — O(log n)</li>
 *   <li>isEmpty() — O(1)</li>
 * </ul>
 * </p>
 *
 * <p>Usa un arreglo dinámico que se redimensiona automáticamente.</p>
 *
 * @author Job Jimenez
 * @version 1.0
 * @see Edge
 * @see Prim
 */
public class MinHeap {

    private static final int DEFAULT_CAPACITY = 16;

    /** Arreglo interno que almacena las aristas. */
    private Edge[] data;

    /** Número actual de aristas en el heap. */
    private int size;

    /**
     * Construye un heap vacío con capacidad inicial por defecto.
     */
    public MinHeap() {
        data = new Edge[DEFAULT_CAPACITY];
        size = 0;
    }

    /**
     * Inserta una arista nueva en el heap.
     *
     * @param edge arista a insertar
     */
    public void insert(Edge edge) {
        ensureCapacity();
        data[size] = edge;
        siftUp(size);
        size++;
    }

    /**
     * Extrae y retorna la arista con menor peso.
     *
     * @return arista mínima del heap
     * @throws IllegalStateException si el heap está vacío
     */
    public Edge extractMin() {
        if (isEmpty())
            throw new IllegalStateException("Heap is empty");

        Edge min = data[0];

        size--;
        data[0] = data[size];
        data[size] = null;
        siftDown(0);

        return min;
    }

    /**
     * Verifica si el heap está vacío.
     *
     * @return {@code true} si no contiene aristas
     */
    public boolean isEmpty() {
        return size == 0;
    }

    /**
     * Retorna el número de aristas actualmente en el heap.
     *
     * @return cantidad de elementos
     */
    public int size() {
        return size;
    }

    /**
     * Mueve una arista hacia arriba hasta restaurar la propiedad del heap.
     *
     * <p>Se llama después de insertar una nueva arista al final.</p>
     *
     * @param i índice del elemento a subir
     */
    private void siftUp(int i) {
        while (i > 0) {
            int parent = (i - 1) / 2;
            if (data[i].weight < data[parent].weight) {
                swap(i, parent);
                i = parent;
            } else {
                break;
            }
        }
    }

    /**
     * Mueve una arista hacia abajo hasta restaurar la propiedad del heap.
     *
     * <p>Se llama después de reemplazar la raíz con el último elemento.</p>
     *
     * @param i índice del elemento a bajar
     */
    private void siftDown(int i) {
        while (true) {
            int smallest = i;
            int left     = 2 * i + 1;
            int right    = 2 * i + 2;

            if (left  < size && data[left].weight  < data[smallest].weight) smallest = left;
            if (right < size && data[right].weight < data[smallest].weight) smallest = right;

            if (smallest == i) break;

            swap(i, smallest);
            i = smallest;
        }
    }

    /**
     * Intercambia dos aristas en el heap.
     *
     * @param a índice del primer elemento
     * @param b índice del segundo elemento
     */
    private void swap(int a, int b) {
        Edge temp = data[a];
        data[a]   = data[b];
        data[b]   = temp;
    }

    /**
     * Amplia el arreglo interno si está lleno.
     */
    private void ensureCapacity() {
        if (size == data.length) {
            Edge[] newData = new Edge[data.length * 2];
            System.arraycopy(data, 0, newData, 0, size);
            data = newData;
        }
    }

    /**
     * Retorna una representación legible del heap.
     *
     * @return cadena con formato {@code [arista1, arista2, ...]}
     */
    @Override
    public String toString() {
        if (size == 0) return "[]";
        StringBuilder sb = new StringBuilder("[");
        for (int i = 0; i < size; i++) {
            sb.append(data[i]);
            if (i < size - 1) sb.append(", ");
        }
        return sb.append("]").toString();
    }
}