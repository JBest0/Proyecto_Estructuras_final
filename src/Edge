/**
 * Representa una arista ponderada y no dirigida entre dos nodos en un grafo.
 * creado para su usa en Prim, por favor indicar si se usa en otro algoritmo
 */
public class Edge {
 
    public int from;
    public int to;
    public double weight;
 
    public Edge(int from, int to, double weight) {
        this.from   = from;
        this.to     = to;
        this.weight = weight;
    }
 
    @Override
    public String toString() {
        return "(" + from + " -> " + to + ", w=" + weight + ")";
    }
}